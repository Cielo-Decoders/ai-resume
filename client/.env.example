# ── Backend API URL ───────────────────────────────────────────────────────────
# In production this must be the Cloud Run backend service URL.
# It is baked into the React bundle at build time.
REACT_APP_API_URL=http://localhost:8000

# ── OpenAI (client-side job description parsing) ──────────────────────────────
REACT_APP_OPENAI_API_KEY=sk-proj-...
