# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Server binding ────────────────────────────────────────────────────────────
# Cloud Run sets PORT automatically; override HOST/PORT only for local dev.
HOST=127.0.0.1
PORT=8000

# ── Application behaviour ─────────────────────────────────────────────────────
DEBUG=True
LOG_LEVEL=INFO
OPENAI_MODEL=gpt-4o-mini

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of extra origins allowed in production.
# Localhost origins are always included.
# Example: https://ai-resume-frontend-abc123-uc.a.run.app,https://mycareerlab.ai
ALLOWED_ORIGINS=
